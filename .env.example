# Copiez ce fichier en .env.local et renseignez les valeurs.
# .env.local n'est jamais commité (voir .gitignore).

# --- Base de données Postgres ---------------------------------------------
# Supabase en v1, portable vers OVH plus tard (Postgres standard, CDC §7.4).
# Utilisez l'URI du POOLER (pgbouncer, mode transaction, port 6543) :
# Supabase → Project Settings → Database → Connection string → "Transaction pooler".
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# --- Emails (F5) -----------------------------------------------------------
# Adresse de réception admin ET reply-to (provisoire tant que le domaine n'est
# pas tranché). Sans elle (ou sans RESEND_API_KEY), l'envoi est simplement sauté.
CONTACT_EMAIL="contact@marssane.fr"

# Clé API Resend (emails transactionnels de pré-inscription).
RESEND_API_KEY=""

# Adresse d'expédition. Défaut si absente : "Marssane <onboarding@resend.dev>"
# (domaine de test Resend, n'envoie qu'à l'adresse du compte). À remplacer par
# une adresse du domaine Marssane une fois SPF/DKIM vérifiés.
# EMAIL_FROM="Marssane <contact@marssane.fr>"

# --- Administration (F3) ---------------------------------------------------
# Secret de signature des sessions admin (JWT HS256, cookie httpOnly).
# Générer une valeur aléatoire : openssl rand -base64 32
AUTH_SECRET=""

# --- Site ------------------------------------------------------------------
# URL publique (sitemap, liens absolus dans les emails).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Benchmarks IA (page « /quelle-ia ») -----------------------------------
# Secret protégeant la route de rafraîchissement /api/benchmarks/refresh.
# Vercel Cron l'envoie automatiquement en en-tête « Authorization: Bearer … ».
# Générer une valeur aléatoire : openssl rand -base64 32
CRON_SECRET=""

# Clé Artificial Analysis (source d'intelligence premium, PAYANTE pour un
# affichage public). Optionnelle : sans elle, la source AA est simplement
# inactive et l'intelligence provient de LMArena (gratuit).
# AA_API_KEY=""
