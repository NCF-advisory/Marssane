{
  "name": "marssane-video",
  "version": "1.0.0",
  "private": true,
  "description": "Vidéo de présentation du héro Marssane (Remotion). Sous-projet isolé.",
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "render:mp4": "remotion render src/index.ts HeroVideo ../public/video/hero.mp4 --codec=h264 --crf=30",
    "render:webm": "remotion render src/index.ts HeroVideo ../public/video/hero.webm --codec=vp9 --crf=36",
    "render:poster": "remotion still src/index.ts HeroVideo ../public/video/hero-poster.jpg --frame=585 --image-format=jpeg --jpeg-quality=88",
    "render:stills": "node scripts/render-stills.mjs",
    "render:all": "npm run render:mp4 && npm run render:webm && npm run render:poster",
    "render:herov2:mp4": "remotion render src/index.ts HeroV2 ../public/video/hero-v2.mp4 --codec=h264 --crf=30",
    "render:herov2:webm": "remotion render src/index.ts HeroV2 ../public/video/hero-v2.webm --codec=vp9 --crf=36",
    "render:herov2:poster": "remotion still src/index.ts HeroV2 ../public/video/hero-v2-poster.jpg --frame=660 --image-format=jpeg --jpeg-quality=88",
    "render:herov2": "npm run render:herov2:mp4 && npm run render:herov2:webm && npm run render:herov2:poster",
    "render:cas1:mp4": "remotion render src/index.ts Cas1Mails ../public/video/cas1.mp4 --codec=h264 --crf=30",
    "render:cas1:webm": "remotion render src/index.ts Cas1Mails ../public/video/cas1.webm --codec=vp9 --crf=36",
    "render:cas1:poster": "remotion still src/index.ts Cas1Mails ../public/video/cas1-poster.jpg --frame=370 --image-format=jpeg --jpeg-quality=88",
    "render:cas1": "npm run render:cas1:mp4 && npm run render:cas1:webm && npm run render:cas1:poster",
    "render:cas2:mp4": "remotion render src/index.ts Cas2Synthese ../public/video/cas2.mp4 --codec=h264 --crf=30",
    "render:cas2:webm": "remotion render src/index.ts Cas2Synthese ../public/video/cas2.webm --codec=vp9 --crf=36",
    "render:cas2:poster": "remotion still src/index.ts Cas2Synthese ../public/video/cas2-poster.jpg --frame=300 --image-format=jpeg --jpeg-quality=88",
    "render:cas2": "npm run render:cas2:mp4 && npm run render:cas2:webm && npm run render:cas2:poster",
    "render:cas3:mp4": "remotion render src/index.ts Cas3Process ../public/video/cas3.mp4 --codec=h264 --crf=30",
    "render:cas3:webm": "remotion render src/index.ts Cas3Process ../public/video/cas3.webm --codec=vp9 --crf=36",
    "render:cas3:poster": "remotion still src/index.ts Cas3Process ../public/video/cas3-poster.jpg --frame=360 --image-format=jpeg --jpeg-quality=88",
    "render:cas3": "npm run render:cas3:mp4 && npm run render:cas3:webm && npm run render:cas3:poster"
  },
  "dependencies": {
    "@remotion/cli": "4.0.488",
    "@remotion/fonts": "4.0.488",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "remotion": "4.0.488",
    "simple-icons": "^16.25.0"
  },
  "devDependencies": {
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "typescript": "5.8.3"
  }
}
